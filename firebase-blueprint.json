{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data stored under their authentication UID.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Matching Authentication UID"
        },
        "username": {
          "type": "string",
          "description": "Unique username chosen by user"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "User primary email address"
        },
        "fullName": {
          "type": "string",
          "description": "Display name of the user"
        },
        "avatarBg": {
          "type": "string",
          "description": "Color class/hex background for avatar"
        }
      },
      "required": ["id", "username", "email", "fullName"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A single financial transaction tracker (income or expense) linked to a user.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string",
          "description": "The UID of the user who owns this transaction"
        },
        "date": {
          "type": "string",
          "format": "date",
          "description": "Date of transaction in YYYY-MM-DD"
        },
        "amount": {
          "type": "number",
          "description": "Transaction amount in Rupiah"
        },
        "type": {
          "type": "string",
          "enum": ["income", "expense"]
        },
        "category": {
          "type": "string",
          "description": "Transaction category, e.g., Gaji, Makanan, Transportasi"
        },
        "method": {
          "type": "string",
          "description": "Payment/Receive method, e.g., Cash, Transfer, E-wallet"
        },
        "purpose": {
          "type": "string",
          "description": "Purpose of expense"
        },
        "notes": {
          "type": "string",
          "description": "Optional notes or description"
        }
      },
      "required": ["id", "userId", "date", "amount", "type", "category"]
    },
    "SavingsTarget": {
      "title": "SavingsTarget",
      "description": "A financial savings target goal/dream which users track and add progress to.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string",
          "description": "UID of owner user"
        },
        "name": {
          "type": "string",
          "description": "Title or description of target dream, e.g. Beli Laptop"
        },
        "targetAmount": {
          "type": "number",
          "description": "The total financial goal amount"
        },
        "currentProgress": {
          "type": "number",
          "description": "The current amount saved towards goal"
        },
        "targetDate": {
          "type": "string",
          "format": "date",
          "description": "Optional target completion date"
        }
      },
      "required": ["id", "userId", "name", "targetAmount", "currentProgress"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Primary user profiles accessible by owners."
    },
    "transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Global user transactions, secured utilizing ownership filters."
    },
    "targets/{targetId}": {
      "schema": "SavingsTarget",
      "description": "Savings targets goals, secured utilizing ownership filters."
    }
  }
}
